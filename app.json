{
  "expo": {
    "name": "MemMem",
    "slug": "MemMem",
    "version": "0.1.3",
    "orientation": "portrait",
    "icon": "./assets/images/demo_icon.png",
    "scheme": "memmem",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/demo_icon.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/demo_android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.MemMem"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f9630fa-6a30-43a1-b2f7-7869e0cffbd5"
      }
    }
  }
}
